        "collapsible_row_Bti8im": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "01",
            "heading": "What kind of commercial laundry equipment do you offer?",
            "row_content": "We offer a wide range of commercial and industrial laundry equipment, including on-premise washers and dryers, coin and card-vended machines, tumble dryers, cabinet dryers, flatwork ironers, light commercial equipment, laundry carts, and other commercial laundry solutions designed for demanding business use."
          }
        },
        "collapsible_row_V4DUcQ": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "02",
            "heading": "Do you sell equipment for laundromats?",
            "row_content": "Yes. We work with laundromat owners on new laundromat projects, laundromat upgrades, retools, and equipment replacements. We can help with the planning process, equipment selection, layout support, installation coordination, and long-term support after the machines are in place."
          }
        },
        "collapsible_row_9BxBG3": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "03",
            "heading": "Do you only sell to laundromats?",
            "row_content": "No. While laundromats are a major focus, we also supply commercial laundry equipment for hospitality businesses, hotels, care homes, healthcare operations, multi-housing properties, lodges, and other organizations that need dependable, high-volume laundry equipment."
          }
        },
        "collapsible_row_4gyRrP": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "04",
            "heading": "Do you offer on-premise laundry equipment?",
            "row_content": "Yes. We offer on-premise laundry machines for businesses that want to process laundry in-house. On-premise equipment can give businesses greater control over quality, turnaround time, and long-term laundry costs."
          }
        },
        "collapsible_row_aHVPBW": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "05",
            "heading": "What types of on-premise laundry machines do you carry?",
            "row_content": "We offer on-premise hardmount washers, softmount washers, single dryers, stacked dryers, and washer-dryer stackers, along with other commercial laundry equipment options depending on the application and facility needs."
          }
        },
        "collapsible_row_Ubek6U": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "06",
            "heading": "Do you offer coin and card-vended laundry equipment?",
            "row_content": "Yes. We offer coin and card-vended commercial laundry machines by Dexter and Wascomat for laundromats and shared laundry rooms. These machines are a strong fit for self-serve laundry environments that need payment flexibility, durable performance, and easy day-to-day operation."
          }
        },
        "collapsible_row_c4azVF": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "07",
            "heading": "Can you help me choose the right commercial laundry equipment?",
            "row_content": "Shopify is a complete commerce platform that lets you start, grow, and manage a business.Create and customize an online store Sell in multiple places, including web, mobile, social media, online marketplaces, brick-and-mortar locations, and pop-up shops."
          }
        },
        "collapsible_row_qkHTWp": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "08",
            "heading": "Do you offer specialty commercial laundry equipment besides washers and dryers?",
            "row_content": "Yes. In addition to washers and dryers, we also offer equipment such as flatwork ironers, cabinet dryers, light commercial products, industrial equipment, and laundry carts to support a more complete laundry setup."
          }
        },
        "collapsible_row_CcCrwN": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "09",
            "heading": "Do you offer compact commercial laundry solutions for smaller laundry rooms?",
            "row_content": "Yes. We can help customers choose compact and space-efficient Huebsch laundry equipment for smaller commercial laundry rooms, shared laundry areas, and properties where layout efficiency matters."
          }
        },
        "collapsible_row_wmHBWx": {
          "type": "collapsible_row",
          "settings": {
            "content_number": "10",
            "heading": "Do you offer financing for commercial laundry equipment?",
            "row_content": "Yes. We can help customers explore third-party financing options for qualifying commercial laundry equipment projects, especially when planning a new laundromat or a major upgrade."
          }
        }
