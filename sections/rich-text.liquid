{{ 'rich-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .richtext_backset{
    background-color: {{section.settings.section_bg}};
  }
  .rich-text__caption{
    color: {{section.settings.richtext_heading}};
  }
  .rich-text__heading{
    color: {{section.settings.richtext_subheading}};
  }
  .rich-text__text{
    color: {{ section.settings.richtext_description }};
  }
  .rich-text__buttons a{
    background-color: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
  }
  .rich-text__blocks {
   text-align: {{ section.settings.text_alignment }};
  }
  .rich-text__buttons a:hover{
    background-color: {{ section.settings.button_hr_bg}};
    color: {{ section.settings.button_hr_text}};
  }
   .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
  }
  @media screen and (max-width: 1429px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1429 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1429 }}px;
      margin-top: {{ section.settings.margin-top-1429 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1429 }}px;
    }
  }
  @media screen and (max-width: 1199px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1199 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1199 }}px;
      margin-top: {{ section.settings.margin-top-1199 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1199 }}px;
    }
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-991 }}px;
      padding-bottom: {{ section.settings.padding-bottom-991 }}px;
      margin-top: {{ section.settings.margin-top-991 }}px;
      margin-bottom: {{ section.settings.margin-bottom-991 }}px;
    }
  }
  @media screen and (max-width: 767px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-767 }}px;
      padding-bottom: {{ section.settings.padding-bottom-767 }}px;
      margin-top: {{ section.settings.margin-top-767 }}px;
      margin-bottom: {{ section.settings.margin-bottom-767 }}px;  
    }
  }
  @media screen and (max-width: 575px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-575 }}px;
      padding-bottom: {{ section.settings.padding-bottom-575 }}px;
      margin-top: {{ section.settings.margin-top-575 }}px;
      margin-bottom: {{ section.settings.margin-bottom-575 }}px;  
    }
  }
{%- endstyle -%}

<div class="isolate richtext_backset d-inline-block section-{{ section.id }}-padding">
  <div class="rich-text content-container {{ section.settings.section_width }}">
    <div class="rich-text__wrapper rich-text__wrapper--{{ section.settings.desktop_content_position }}">
      <div class="rich-text__blocks">
          {% if section.settings.caption != blank %}
          <div class="rich-text__caption theme_main_subheading {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.caption | escape }}
          </div>
          {% endif %}
          {% if section.settings.heading != blank %}
            <div class="rich-text__heading inline-richtext h2 theme_main_heading {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              {{ section.settings.heading }}
            </div>
            {% endif %}
            {% if section.settings.text != blank %}
              <div class="rich-text__text theme_main_description {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                {{ section.settings.text }}
              </div>
           {% endif %}
           <div class="rich-text__buttons{% if section.settings.button_label != blank %} rich-text__buttons--multiple{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {%- if section.settings.button_label != blank -%}
              <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true" {% else %} href="{{ section.settings.button_link }}" {% endif %} class="button theme_buttons">
                {{- section.settings.button_label | escape -}}
              </a>
            {%- endif -%}
          </div>
      </div>
    </div>
  </div>
</div>

