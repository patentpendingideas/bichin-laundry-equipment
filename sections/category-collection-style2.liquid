{{ 'category-collection-style2.css' | asset_url | stylesheet_tag }}
<div class="category-collection-style2 main-collection-list-item3 {{ section.settings.section_width }} {{ section.settings.category_style }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="section-{{ section.id }}-padding">
    <div class="main-collection-item main-collection-item--{{ section.settings.text_alignment }}">
      {% if section.settings.heading-img != blank or section.settings.main_subheading != blank or section.settings.main_heading != blank or section.settings.main_paragraph != blank %}
        <div class="collection_title_wrap title_bottom_margin">
          {% if section.settings.heading-img != blank %}
            <div class="heading-img w-100 {{ section.settings.text_alignment }}">
              <img src="{{ section.settings.heading-img | img_url: 'master' }}" alt="slider-img" class="w-100" loading="eager">
            </div>
          {% endif %}
          {% if section.settings.main_subheading != blank %}<div class="theme_main_subheading">{{ section.settings.main_subheading }}</div>{% endif %}
          {% if section.settings.main_heading != blank %}<div class="theme_main_heading h2">{{ section.settings.main_heading }}</div>{% endif %}
          {% if section.settings.main_paragraph != blank %}<p class="theme_main_description">{{ section.settings.main_paragraph }}</p>{% endif %}
        </div>
        {% endif %}
        <div class="category_style_wrapper">
          <div class="main-collections-list-wrapper swiper-container"
            data-desktop="{{ section.settings.collection-desktop }}" data-largetablet="{{ section.settings.collection-large-tablet }}" data-tablet="{{ section.settings.collection-tablet }}" 
            data-mobile="{{ section.settings.collection-mobile }}" data-autoplay="{{ section.settings.autoplay-enable }}"
            data-speed="{{ section.settings.speed }}" data-loop="{{ section.settings.loop }}" data-slider="{{ section.settings.category_style }}">
            <div class="collection-list swiper-wrapper">
              {% for block in section.blocks %}
              {% if block.type == 'collection' %}
              {%- assign featured_collection = collections[block.settings.collection] -%}
              {%- assign featured_image = block.settings.image -%}
              {%- assign collectionTitle = featured_collection.title | default: 'Collection' -%}
              <div class="main-collection-list swiper-slide" {{ block.shopify_attributes }}>
                <div class="collection-card__image">
                  <div class="category_img">
                      {%- if featured_image != blank -%}
                        <div class="media media--transparent ratio" style="--ratio-percent: {{ block.settings.image-ratio }}%">
                          {{ featured_image | image_url: width: 1920 | image_tag : loading: 'lazy', class: 'w-100' }}
                        </div>
                        {% else %}
                        <div class="media media--transparent ratio" style="--ratio-percent: {{ block.settings.image-ratio }}%">
                          {%- capture current -%}{%- cycle 1, 2, 3, 4, 5, 6 -%}{%- endcapture -%}
                          {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                        </div>
                      {%- endif -%}
                  </div>
                  
                    <div class="collection-name-wrapper">
                      <div class="h3">
                        {% if block.settings.title != blank %}
                          {{ block.settings.title }}
                        {% else %}
                          {{ collectionTitle }}
                        {% endif %}
                      </div>
                      {% if section.settings.category_style == 'classic' %}
                        <span class="collection-product-count">{{ featured_collection.products_count | default: 0 }}</span>
                      {% endif %}
                      
                    </div>
                    <div class="sub-category">
                      <div class="subcategory">
                        <a {% if featured_collection.url==blank %} role="link" aria-disabled="true" {% else %}
                          href="{{ featured_collection.url }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.title }}">
                          <div class="h3">
                            {% if block.settings.title != blank %}
                              {{ block.settings.title }}
                            {% else %}
                              {{ collectionTitle }}
                            {% endif %}
                           </div>
                        </a>
                        {% if block.settings.category1 != blank %}
                          <a {% if block.settings.category1_link == blank %} role="link" aria-disabled="true" {% else %}
                            href="{{ block.settings.category1_link }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.category1 }}">
                            {% render 'icon-c-right' %}{{ block.settings.category1 }}
                          </a>
                        {% endif %}
                        {% if block.settings.category2 != blank %}
                          <a {% if block.settings.category2_link == blank %} role="link" aria-disabled="true" {% else %}
                            href="{{ block.settings.category2_link }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.category2 }}">
                            {% render 'icon-c-right' %}{{ block.settings.category2 }}
                          </a>
                        {% endif %}
                        {% if block.settings.category3 != blank %}
                          <a {% if block.settings.category3_link == blank %} role="link" aria-disabled="true" {% else %}
                            href="{{ block.settings.category3_link }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.category3 }}">
                            {% render 'icon-c-right' %}{{ block.settings.category3 }}
                          </a>
                        {% endif %}
                        {% if block.settings.category4 != blank %}
                          <a {% if block.settings.category4_link == blank %} role="link" aria-disabled="true" {% else %}
                            href="{{ block.settings.category4_link }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.category4 }}">
                            {% render 'icon-c-right' %}{{ block.settings.category4 }}
                          </a>
                        {% endif %}
                        {% if block.settings.category5 != blank %}
                          <a {% if block.settings.category5_link == blank %} role="link" aria-disabled="true" {% else %}
                            href="{{ block.settings.category5_link }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.category5 }}">
                            {% render 'icon-c-right' %}{{ block.settings.category5 }}
                          </a>
                        {% endif %}
                        {% if block.settings.category6 != blank %}
                          <a {% if block.settings.category6_link == blank %} role="link" aria-disabled="true" {% else %}
                            href="{{ block.settings.category6_link }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.category6 }}">
                            {% render 'icon-c-right' %}{{ block.settings.category6 }}
                          </a>
                        {% endif %}
                        {% if block.settings.category7 != blank %}
                          <a {% if block.settings.category7_link == blank %} role="link" aria-disabled="true" {% else %}
                            href="{{ block.settings.category7_link }}" {% endif %} class="sub-category-text" aria-label="{{ block.settings.category7 }}">
                            {% render 'icon-c-right' %}{{ block.settings.category7 }}
                          </a>
                        {% endif %}
                      </div>
                        
                    </div>

                </div>
              </div>
              {% endif %}
              {% endfor %}
            </div>
            {% if section.settings.arrows %}
            <div class="swiper-buttons">
              <div class="content-buttons">
                <div class="swiper-button-next second-category-swiper-button-next">{% render 'icon-caret' %}</div>
                <div class="swiper-button-prev second-category-swiper-button-prev">{% render 'icon-caret' %}</div>
              </div>
            </div>
            {% endif %}
            {% if section.settings.dots -%}
            <div class="swiper-pagination second-category-swiper-pagination" id="swiper-pagination-{{section.id}}" style="position: inherit;"></div>
            {% endif %}
          </div>
      </div>
    </div>
  </div>
</div>

{% style %}
  .category-collection-style2.main-collection-list-item3 .heading-img.center{
    margin: 0 auto;
  }
  .category-collection-style2.main-collection-list-item3 .heading-img.right{
    margin: 0 0 0 auto;
  }
  .category-collection-style2 .collection_title_wrap .theme_main_heading {
    color: {{ section.settings.heading_color }};
  }
  .category-collection-style2 .collection_title_wrap .theme_main_subheading {
    color: {{ section.settings.subheading_color }};
  }
  .category-collection-style2 .collection_title_wrap .theme_main_description{
    color: {{ section.settings.content_color }};
  }
  .category-collection-style2 .swiper-button-next,
  .category-collection-style2 .swiper-button-prev{
    background: {{ settings.button_bg }}; 
    color: {{ settings.button_text }};
  }
  .category-collection-style2 .swiper-button-next:hover,
  .category-collection-style2 .swiper-button-prev:hover{
    background: {{ settings.button_hr_bg }}; 
    color: {{ settings.button_hr_text }};
  }
  .category-collection-style2 .swiper-pagination-bullet { 
    background: {{ settings.theme_dots }}; 
  }  
  .category-collection-style2 .swiper-pagination-bullet.swiper-pagination-bullet-active { 
    background: {{ settings.theme_dots_active }};
  }
  .category-collection-style2.main-collection-list-item3 .collection-name-wrapper{
    background-color: {{ section.settings.collection_bg }};
    color: {{ section.settings.collection-name-color }};
  }
  .category-collection-style2.main-collection-list-item3 .collection-product-count {
    background-color: {{ section.settings.count_bg }};
    color: {{ section.settings.count_text }};
  }
  .category-collection-style2.main-collection-list-item3 .sub-category{
    background-color: {{ section.settings.collection_bg }};
    color: {{ section.settings.collection-name-color }};
  }
  .category-collection-style2 .sub-category .h3{
    color: {{ section.settings.collection-name-color }};
  }
  .category-collection-style2 .sub-category a{
    color: {{ section.settings.subcategory-name-color }};
  }
  .category-collection-style2 .sub-category a:hover,
  .category-collection-style2 .sub-category .h3:hover{
    color: {{ section.settings.collection-hover-name-color }};
  }
  .category_style2{
    background-color: {{ section.settings.bg_color }};
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
  }
  @media screen and (max-width: 1429px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1429 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1429 }}px;
      margin-top: {{ section.settings.margin-top-1429 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1429 }}px;
    }
  }
  @media screen and (max-width: 1199px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1199 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1199 }}px;
      margin-top: {{ section.settings.margin-top-1199 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1199 }}px;
    }
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-991 }}px;
      padding-bottom: {{ section.settings.padding-bottom-991 }}px;
      margin-top: {{ section.settings.margin-top-991 }}px;
      margin-bottom: {{ section.settings.margin-bottom-991 }}px;
    }
  }
  @media screen and (max-width: 767px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-767 }}px;
      padding-bottom: {{ section.settings.padding-bottom-767 }}px;
      margin-top: {{ section.settings.margin-top-767 }}px;
      margin-bottom: {{ section.settings.margin-bottom-767 }}px;  
    }
  }
  @media screen and (max-width: 575px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-575 }}px;
      padding-bottom: {{ section.settings.padding-bottom-575 }}px;
      margin-top: {{ section.settings.margin-top-575 }}px;
      margin-bottom: {{ section.settings.margin-bottom-575 }}px;  
    }
  }
{% endstyle %}

