{{ 'cms-style1.css' | asset_url | stylesheet_tag }}

<div class="cms-style1-wrapper section-{{ section.id }}-padding section-{{ section.id }}-margin {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="{{ section.settings.section_width }}">
    <div class="cms-style1-inner-flex">
      <div class="cms-style1-left-pannel">
        {% if section.settings.cms_left_image != blank %}
          <div class="media media--transparent ratio" style="--ratio-percent: 117.243%">
            {{ section.settings.cms_left_image | image_url: width: 1920 | image_tag : loading: 'lazy', class: 'w-100' }}
          </div>
          {% else %}
          <div class="media media--transparent ratio" style="--ratio-percent: 117.243%">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
          </div>
        {% endif %}
      </div>
      <div class="cms-style1-right-pannel">
        <div class="cms-style1-content-wrap">
          <div class="cms-style1-top-content">
            {% if section.settings.cms_subheading != blank %}
                <div class="theme_main_subheading cms_1_subheading">{{ section.settings.cms_subheading }}</div>
            {% endif %}
            {% if section.settings.cms_heading != blank %}
                <div class="theme_main_heading cms_1_heading h2">{{ section.settings.cms_heading }}</div>
            {% endif %}
            {% if section.settings.cms_description != blank %}
                <div class="theme_main_description cms_1_description">{{ section.settings.cms_description }}</div>
            {% endif %}
            <a {% if section.settings.cms-style-1-btn-url %} href="{{ section.settings.cms-style-1-btn-url }}" {% else %}
            role="link" aria-disabled="true" {% endif %} class="button theme_buttons cms_style1_button" aria-label="{{ section.settings.cms-style-1-btn }}">{{ section.settings.cms-style-1-btn }}</a>
          </div>
          <div>
            {% if section.settings.cms_right_image != blank %}
            <div class="media media--transparent ratio" style="--ratio-percent: 68.703%">
              {{ section.settings.cms_right_image | image_url: width: 1920 | image_tag : loading: 'lazy', class: 'w-100' }}
            </div>
            {% else %}
            <div class="media media--transparent ratio" style="--ratio-percent: 68.703%">
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% style %}
  .cms_style_section{
    background: {{ section.settings.section_bg }};
  }
  .cms-style1-right-pannel:before{
    background: {{ section.settings.content_bg }};
  }
  .cms_1_subheading{
    color: {{ section.settings.subheading_color }};
  }
  .cms_1_heading{
    color: {{ section.settings.heading_color }};
  }
  .cms_1_description{
    color: {{ section.settings.content_color }};
  }
  .cms_style1_button {
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
  }
  .cms_style1_button:hover {
    background: {{ section.settings.button_bg_hover }};
    color:{{ section.settings.button_text_hover }}; 
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
  }
  @media screen and (max-width: 1429px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1429 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1429 }}px;
      margin-top: {{ section.settings.margin-top-1429 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1429 }}px;
    }
  }
  @media screen and (max-width: 1199px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1199 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1199 }}px;
      margin-top: {{ section.settings.margin-top-1199 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1199 }}px;
    }
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-991 }}px;
      padding-bottom: {{ section.settings.padding-bottom-991 }}px;
      margin-top: {{ section.settings.margin-top-991 }}px;
      margin-bottom: {{ section.settings.margin-bottom-991 }}px;
    }
  }
  @media screen and (max-width: 767px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-767 }}px;
      padding-bottom: {{ section.settings.padding-bottom-767 }}px;
      margin-top: {{ section.settings.margin-top-767 }}px;
      margin-bottom: {{ section.settings.margin-bottom-767 }}px;  
    }
  }
  @media screen and (max-width: 575px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-575 }}px;
      padding-bottom: {{ section.settings.padding-bottom-575 }}px;
      margin-top: {{ section.settings.margin-top-575 }}px;
      margin-bottom: {{ section.settings.margin-bottom-575 }}px;  
    }
  }
{% endstyle %}

