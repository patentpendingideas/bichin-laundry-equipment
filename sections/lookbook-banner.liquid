{{ 'lookbook-banner.css' | asset_url | stylesheet_tag }}
<div class="main-lookbook-section section-{{ section.id }}-padding {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="{{ section.settings.section_width }}">
    <div class="main-lookbook-section-wrapper main-lookbook-section-wrapper--{{ section.settings.text_alignment }}">
      {% if section.settings.heading-img != blank or section.settings.main_subheading != blank or section.settings.main_heading != blank or section.settings.main_paragraph != blank %}
        <div class="lookbook_title_wrap title_bottom_margin">
          {% if section.settings.heading-img != blank %}
            <div class="heading-img w-100 {{ section.settings.text_alignment }}">
              <img src="{{ section.settings.heading-img | img_url: 'master' }}" alt="slider-img" class="w-100" loading="eager">
            </div>
          {% endif %}
          {% if section.settings.main_subheading != blank %}<div class="theme_main_subheading">{{ section.settings.main_subheading }}</div>{% endif %}
          {% if section.settings.main_heading != blank %}<div class="theme_main_heading h2">{{ section.settings.main_heading }}</div>{% endif %}
          {% if section.settings.main_paragraph != blank %}<p class="theme_main_description">{{ section.settings.main_paragraph }}</p>{% endif %}
        </div>
      {% endif %}
      <div
        class="main-lookbook-inner">
        {% for block in section.blocks %}
          {% if block.type == 'lookbook' %}
          {%- assign first_product = all_products[block.settings.first_lookbook_product] -%}
          {%- assign second_product = all_products[block.settings.second_lookbook_product] -%}
            <div class="main-lookbook-list  lg-col-{{ block.settings.block-width }}">
              <div class="main-lookbook-list-wrapper">
                {% if block.settings.lookbook_img != blank %}
                  <div class="media media--transparent ratio" style="--ratio-percent: {{ block.settings.img-height }}%">
                    {{ block.settings.lookbook_img | image_url: width: 1920 | image_tag : loading: 'lazy', class: 'w-100' }}
                  </div>
                  {% else %}
                  <div class="media media--transparent ratio" style="--ratio-percent: {{ block.settings.img-height }}%">
                    {{ 'collection-6' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                  </div>
                {% endif %}
                <div class="button_product lookbook first_lookbook_product lookbook-{{ block.id }}">
                  <div class="button_point"> + </div>
                  <div class="custom-product-card">
                    {% if block.settings.first_lookbook_product != blank %}
                    {% render 'card-product',
                      card_product: first_product,
                      media_aspect_ratio: settings.p_image_ratio,
                      show_secondary_image: settings.p_show_secondary_image,
                      show_vendor: settings.p_show_vendor,
                      show_rating: settings.p_show_rating,
                      section_id: section.id
                    %}
                    {% else %}
                    <div class="card">
                      <a class="card__inner">
                        {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                        {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                      </a>
                      <div class="product-collection__content">
                        <h3 class="product-collection__title">
                          <a class="cd">{{ 'onboarding.product_title' | t }}</a>
                        </h3>
                        <span class="price price--sale">
                          <span class="current"><span class="money">RS.59.00</span></span>
                        </span>
                      </div>
                    </div>
                    {% endif %}
                  </div>
                </div>
  
                <div class="button_product lookbook second_lookbook_product lookbook-{{ block.id }}">
                  <div class="button_point"> + </div>
                  <div class="custom-product-card">
                    {% if block.settings.second_lookbook_product != blank %}
                    {% render 'card-product',
                      card_product: second_product,
                      media_aspect_ratio: settings.p_image_ratio,
                      show_secondary_image: settings.p_show_secondary_image,
                      show_vendor: settings.p_show_vendor,
                      show_rating: settings.p_show_rating,
                      section_id: section.id
                    %}
                    {% else %}
                    <div class="card">
                      <a class="card__inner">
                        {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                        {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                      </a>
                      <div class="product-collection__content">
                        <h3 class="product-collection__title">
                          <a class="cd">{{ 'onboarding.product_title' | t }}</a>
                        </h3>
                        <span class="price price--sale">
                          <span class="current"><span class="money">RS.59.00</span></span>
                        </span>
                      </div>
                    </div>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% style %}
  .lookbook_title_wrap .heading-img.center{
    margin: 0 auto;
  }
  .lookbook_title_wrap .heading-img.right{
    margin: 0 0 0 auto;
  }
  .lookbook_title_wrap .theme_main_subheading {
    color: {{ section.settings.theme_subheading_color }};
  }
  .lookbook_title_wrap .theme_main_description{
    color: {{ section.settings.content_color }};
  }
  .lookbook_title_wrap .theme_main_heading {
    color: {{ section.settings.theme_heading_color }};
  }
  .main-lookbook-section .button_product .button_point{
    background-color: {{ section.settings.lookbook_button_bg }};
    outline: 1px solid {{ section.settings.lookbook_button_bg }};
    color:{{ section.settings.lookbook_button_text }};
    transition: all .5s ease;
  }
 .main-lookbook-section .product-card-wrapper .product_vendor {
    color: {{ settings.card_product_vendor_color }};
  }
  .main-lookbook-section .product-card-wrapper .card__heading a, .product_tile_size_holder, .swatch-anchor{
    color: {{ settings.card_product_title_color }};
  }
  .main-lookbook-section .product-card-wrapper .card__heading a:hover{
    color: {{ settings.card_product_title_hr_color }};
  }
  .main-lookbook-section .product-card-wrapper .price .price-item--regular {
    color: {{ settings.card_product_sale_price_color }};
  }
  .main-lookbook-section .product-card-wrapper .price .price-item--last {
    color: {{ settings.card_product_regular_price_color }};
  }
  .main-lookbook-section .custom-product-card .card{
    background-color: {{ section.settings.lookbook_card_bg }};
  }
  {%- for block in section.blocks -%}
    {%- case block.type -%}
    {%- when 'lookbook' -%}
      .main-lookbook-section .first_lookbook_product.lookbook-{{ block.id }}{
        top: {{ block.settings.first_coordinates_y }}%;
        left: {{ block.settings.first_coordinates_x }}%;
      }
      .main-lookbook-section .second_lookbook_product.lookbook-{{ block.id }}{
        top: {{ block.settings.second_coordinates_y }}%;
        left: {{ block.settings.second_coordinates_x }}%;
      }
    {% endcase %}
  {% endfor %}
  .lookbook_section{
    background-color: {{ section.settings.bg_color }};
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
  }
  @media screen and (max-width: 1429px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1429 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1429 }}px;
      margin-top: {{ section.settings.margin-top-1429 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1429 }}px;
    }
  }
  @media screen and (max-width: 1199px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1199 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1199 }}px;
      margin-top: {{ section.settings.margin-top-1199 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1199 }}px;
    }
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-991 }}px;
      padding-bottom: {{ section.settings.padding-bottom-991 }}px;
      margin-top: {{ section.settings.margin-top-991 }}px;
      margin-bottom: {{ section.settings.margin-bottom-991 }}px;
    }
  }
  @media screen and (max-width: 767px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-767 }}px;
      padding-bottom: {{ section.settings.padding-bottom-767 }}px;
      margin-top: {{ section.settings.margin-top-767 }}px;
      margin-bottom: {{ section.settings.margin-bottom-767 }}px;  
    }
  }
  @media screen and (max-width: 575px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-575 }}px;
      padding-bottom: {{ section.settings.padding-bottom-575 }}px;
      margin-top: {{ section.settings.margin-top-575 }}px;
      margin-bottom: {{ section.settings.margin-bottom-575 }}px;  
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Lookbook banner",
  "tag": "section",
  "class": "section lookbook_section",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "full_width",
          "label": "Full width"
        },
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "padding_width",
          "label": "With padding"
        }
      ],
      "label": "Section width",
      "default": "full_width"
    },
    {
      "type": "header",
      "content": "Title setting"
    },
    {
      "type" : "image_picker",
      "id" : "heading-img",
      "label" : "Heading image"
    },
    {
      "type": "text",
      "id": "main_subheading",
      "label": "Subheading",
      "default": "Lookbook"
    },
    {
      "type": "textarea",
      "id": "main_heading",
      "label": "Heading",
      "default": "Lookbook collection products"
    },
    {
      "type": "textarea",
      "id": "main_paragraph",
      "label": "Content",
      "default": "Pair text with an image to focus on your chosen product."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Main title alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Color settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "theme_heading_color",
      "label": "Heading color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "theme_subheading_color",
      "label": "Subheading color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "lookbook_card_bg",
      "label": "Lookbook card bg color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "lookbook_button_bg",
      "label": "Lookbook button bg color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "lookbook_button_text",
      "label": "Lookbook button icon color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "number",
      "id": "padding-top",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "number",
      "id": "padding-bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "Screen wise section padding"
    },
    {
      "type": "header",
      "content": "@media screen 1429"
    },
    {
      "type": "number",
      "id": "padding-top-1429",
      "label": "Padding top",
      "default": 70
    },
    {
      "type": "number",
      "id": "padding-bottom-1429",
      "label": "Padding bottom",
      "default": 70
    },
    {
      "type": "header",
      "content": "@media screen 1199"
    },
    {
      "type": "number",
      "id": "padding-top-1199",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "number",
      "id": "padding-bottom-1199",
      "label": "Padding bottom",
      "default": 60
    },
    {
