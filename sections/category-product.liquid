      "label": "t:sections.social_media_collage.settings.main_title_alignment"
    },
    {
      "type": "header",
      "content": "Color settings"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "collection_text_bg",
      "label": "Collection text bg color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "collection-name-color",
      "label": "Collection text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "count_bg",
      "label": "Count bg color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "count_text",
      "label": "Count text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "number",
      "id": "padding-top",
      "label": "t:sections.all.padding.padding_top",
