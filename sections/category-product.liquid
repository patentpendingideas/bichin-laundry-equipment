{{ 'category-product.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{% if settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if settings.p_enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<div class="isolate section-{{ section.id }}-padding best-selling-product-{{ section.id }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="category-product collection section-{{ section.id }}-padding-inner">
    <div class="{{ section.settings.section_width }}">
      {% if section.settings.heading-img != blank or section.settings.collections_subtitle != blank or section.settings.collections_title != blank or section.settings.collections_description != blank %}
        <div class="collection_product_title title_bottom_margin">
          {% if section.settings.heading-img != blank %}
            <div class="heading-img w-100 {{ section.settings.main_title_alignment }}">
              <img src="{{ section.settings.heading-img | img_url: 'master' }}" alt="slider-img" class="w-100" loading="eager">
            </div>
          {% endif %}
          {%- if section.settings.collections_subtitle != blank -%}
            <div class="theme_main_subheading">{{ section.settings.collections_subtitle }}</div>
          {% endif %}
          {%- if section.settings.collections_title != blank -%}
            <div class="theme_main_heading h2">{{ section.settings.collections_title }}</div>
          {%- endif -%}
          {%- if section.settings.collections_description != blank -%}
            <div class="theme_main_description">{{ section.settings.collections_description }}</div>
          {% endif %}
        </div>
      {% endif %}
      <div class="best-selling-product-collections-wrapper">
        {% for block in section.blocks %}
          {% case block.type %}
          {% when 'product' %}
            <div class="category-product-row">
              <div class="category-banner">
                <div class="category-collection-banner">
                  <a {% if block.settings.collection.url==blank %} role="link" aria-disabled="true" {% else %}
                  href="{{ block.settings.collection.url }}" {% endif %} class="collection-name" aria-label="{{ block.settings.title }}">
                    {% if block.settings.collection_img != blank %}
                      <div class="media media--transparent ratio" style="--ratio-percent: 103.826%">
                        {{ block.settings.collection_img | image_url: width: 1920 | image_tag : loading: 'lazy', class: 'w-100' }}
                      </div>
                      {% else %}
                      <div class="media media--transparent ratio" style="--ratio-percent: 103.826%">
                        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                      </div>
                    {% endif %}
                    {%- assign collectionTitle = block.settings.collection.title | default: 'Collection' -%}
                  
                    <div class="collection-name-wrapper">
                      <div class="h3">
                        {% if block.settings.title != blank %}
                          {{ block.settings.title }}
                        {% else %}
                          {{ collectionTitle }}
                        {% endif %}
                       </div>
                      <span class="collection-product-count">{{ block.settings.collection.products_count | default: 0 }}</span>
                    </div>
                  </a>
                </div>
              </div>
              <div class="best-selling-product-collections">
                <slider-component class="">
                  <ul
                    id="Slider-{{ section.id }}"
                    class="product-grid contains-card contains-card--product
                    {% if settings.card_style == 'standard' %} contains-card--standard{% endif %} 
                    grid"
                    role="list"
                    aria-label="{{ 'general.slider.name' | t }}"
                  >
                    {%- for product in block.settings.collection.products limit: block.settings.products_to_show -%}
                      <li
                        id="Slide-{{ section.id }}-{{ forloop.index }}" 
                        class="grid__item"
                      >
                        {% render 'card-product',
                          card_product: product,
                          media_aspect_ratio: settings.p_image_ratio,
                          image_shape: settings.p_image_shape,
                          show_secondary_image: settings.p_show_secondary_image,
                          show_vendor: settings.p_show_vendor,
                          show_badge: settings.show_badge,
                          show_countdown: settings.p_show_countdown,
                          show_rating: settings.p_show_rating,
                          show_quick_add: settings.p_enable_quick_add,
                          quantity_enable: settings.p_quantity_enable,
                          enable_product_variants: settings.p_variants_enable,
                          section_id: section.id
                        %}
                      </li>
                    {%- else -%}
                      {%- for i in (1..4) -%}
                        <li
                          class="grid__item"
                        >
                          {%- assign placeholder_image = 'product-' | append: forloop.rindex -%}
                          {% render 'card-product',
                            show_vendor: settings.p_show_vendor,
                            placeholder_image: placeholder_image
                          %}
                        </li>
                      {%- endfor -%}
                    {%- endfor -%}
                  </ul>
                </slider-component>
              </div>
            </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{%- style -%}
  .category-product .heading-img.center{
    margin: 0 auto;
  }
  .category-product .heading-img.right{
    margin: 0 0 0 auto;
  }
  .category-product .quantity:after{
    border: 1px solid {{ settings.q_button_border }};
  }
  .category-product .quantity__input{
    color: {{ settings.q_button_color }};
  }
  .category-product .quantity__button{
    background-color: {{ settings.q_button_bg }} !important;
    color: {{ settings.q_button_color }};
  }
  .category-product .quantity__button:hover{
    background-color: {{ settings.q_button_hr_bg }} !important;
    color: {{ settings.q_button_hr_color }};
  }
  .category-product .collection_product_title {
    text-align: {{ section.settings.main_title_alignment }};
  }
  .category-product .theme_main_subheading{
    color: {{ section.settings.subheading_color }};
  }
  .category-product .theme_main_heading{
    color: {{ section.settings.heading_color }};
  }
  .category-product .theme_main_description{
    color: {{ section.settings.content_color }};
  }
  .category-product .product-card-wrapper .product_vendor {
    color: {{ settings.card_product_vendor_color }};
  }
  .category-product .product-card-wrapper .card__heading a, .product_tile_size_holder, .swatch-anchor{
    color: {{ settings.card_product_title_color }};
  }
  .category-product .product-card-wrapper .card__heading a:hover{
    color: {{ settings.card_product_title_hr_color }};
  }
  .category-product .product-card-wrapper .price .price-item--regular {
    color: {{ settings.card_product_sale_price_color }};
  }
  .category-product .product-card-wrapper .price .price-item--last {
    color: {{ settings.card_product_regular_price_color }};
  }
  .category-product .quick-add__submit,
  .category-product .product-hover button{
    background-color: {{ settings.card_button_bg }};
    color: {{ settings.card_button_text }};
  }
  .category-product .quick-add__submit:hover,
  .category-product .product-hover button:hover{
    background-color: {{ settings.card_button_hr_bg }};
    color: {{ settings.card_button_hr_text }};
  }
  .category-product .product-hover .active .icon.icon-wishlist,
  .category-product .product-hover .active .icon.icon-compare{
    fill: {{ settings.card_button_text }};
    color: {{ settings.card_button_text }};
  }
  .category-product .product-hover button:hover.active .icon.icon-wishlist,
  .category-product .product-hover button:hover.active .icon.icon-compare{
    fill: {{ settings.card_button_hr_text }};
    color: {{ settings.card_button_hr_text }};
  }
  .category-product .countdown-timer .main-c-motel{
    background-color: {{ settings.countdown_bg }};
    color: {{ settings.countdown_text }};
  }
  .category-product .heading-img.center{
    margin: 0 auto;
  }
  .category-product .heading-img.right{
    margin: 0 0 0 auto;
  }
  .category-product .collection-name-wrapper {
    background-color: {{ section.settings.collection_text_bg }};
  }
  .category-product .collection-name-wrapper .h3{
    color: {{ section.settings.collection-name-color }};
  }
  .category-product .collection-product-count{
    background:{{ section.settings.count_bg }};
    color:{{ section.settings.count_text }};
  }
  .category-product .best-selling-product-collections slider-component::-webkit-scrollbar-thumb {
    background: {{ settings.theme_main_color }};
  }
  .category-product .best-selling-product-collections slider-component::-webkit-scrollbar-track {
    background: {{ settings.border_color }};
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
    margin-top: {{ section.settings.margin-top }}px;
    margin-bottom: {{ section.settings.margin-bottom }}px;
    background-color: {{section.settings.section_bg}};
  }
   @media screen and (max-width: 1429px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1429 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1429 }}px;
      margin-top: {{ section.settings.margin-top-1429 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1429 }}px;
    }
  }
  @media screen and (max-width: 1199px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-1199 }}px;
      padding-bottom: {{ section.settings.padding-bottom-1199 }}px;
      margin-top: {{ section.settings.margin-top-1199 }}px;
      margin-bottom: {{ section.settings.margin-bottom-1199 }}px;
    }
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-991 }}px;
      padding-bottom: {{ section.settings.padding-bottom-991 }}px;
      margin-top: {{ section.settings.margin-top-991 }}px;
      margin-bottom: {{ section.settings.margin-bottom-991 }}px;
    }
  }
  @media screen and (max-width: 767px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-767 }}px;
      padding-bottom: {{ section.settings.padding-bottom-767 }}px;
      margin-top: {{ section.settings.margin-top-767 }}px;
      margin-bottom: {{ section.settings.margin-bottom-767 }}px;  
    }
  }
  @media screen and (max-width: 575px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding-top-575 }}px;
      padding-bottom: {{ section.settings.padding-bottom-575 }}px;
      margin-top: {{ section.settings.margin-top-575 }}px;
      margin-bottom: {{ section.settings.margin-bottom-575 }}px;  
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Category product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "full_width",
          "label": "Full width"
        },
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "padding_width",
          "label": "With padding"
        }
      ],
      "label": "Section width",
      "default": "full_width"
    },
    {
      "type": "header",
      "content": "Title settings"
    },
    {
      "type" : "image_picker",
      "id" : "heading-img",
      "label" : "Heading image"
    },
    {
      "type": "text",
      "id": "collections_subtitle",
      "label": "t:sections.featured-collection.settings.subheading.label",
      "default": "Text about your branding"
    },
    {
      "type": "textarea",
      "id": "collections_title",
      "label": "t:sections.multicolumn.settings.title.label",
      "default": "Featured collection"
    },
    {
      "type": "textarea",
      "id": "collections_description",
      "label": "t:sections.featured-collection.settings.description.label",
      "default": "Pair text with an image to focus on your brand and description of your brand."
    },
    {
      "type": "select",
      "id": "main_title_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.social_media_collage.settings.left"
        },
        {
          "value": "center",
          "label": "t:sections.social_media_collage.settings.center"
        },
        {
          "value": "right",
          "label": "t:sections.social_media_collage.settings.right"
        }
