        "label": "Heading",
        "default": "About us"
      },
      {
        "type": "textarea",
        "id": "section_description",
        "default": "Pair text with an image to focus on your chosen product, collection, or about us content.",
        "label": "Content"
      },
      {
        "type": "select",
        "id": "main_title_alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "left",
        "label": "Main title alignment"
      },
      {
        "type": "select",
        "id": "banner_type",
        "options": [
          {
            "value": "image",
            "label": "Image"
          },
          {
            "value": "video",
            "label": "Local video"
          },
          {
            "value": "online-video",
            "label": "Online video"
          }
