{% doc %}
  @prompt
    Please add a new Rich Text Section with transparent text boxes that have a dropdown option to change the text to H1, H2, H3, H4, H5, H6, and paragraph, another option to change the text size, another option to change the text colour, and a rich formatting tool kit that is usually standard with rich text.  Also include the option in each text box to toggle a button on or off and include the ability to link it to other pages or collections within the website.
    
    Please include an option to move each text box’s position up or down within the section, above or below others.
    
    The section should have the option to add up to 10 additional text boxes, all with the options listed above.
    
    The Rich Text section should mirror what is in each text box, so that spacing between paragraphs, text alignment, text size, etc. shows up on the section the same way it shows up in the text box. 
    
    The background should have this gradient coding:
    > div {
      background: linear-gradient(
        to bottom right,
        #bb941b 0%,
        #e0c55a 25%,
        #be9722 50%,
        #c6a228 75%,
        #ebce66 100%
      );
    }
    
    Please add an optional image placeholder that can be toggled on or off and moved up or down in the section and be used or hidden at the user’s discretion. 
    
    Add a button at the bottom that is fully customizable, colours of the text, size of the text, and all other normal text parameters., remove the white background in the text boxes and make them transparent, Center all the text boxes, add the option to align text left, centre or right in each text box, add the option to add an image in each text box
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(
      to bottom right,
      #bb941b 0%,
      #e0c55a 25%,
      #be9722 50%,
      #c6a228 75%,
      #ebce66 100%
    );
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-rich-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing_between_items }}px;
    align-items: center;
  }

  .ai-rich-text-item-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    background: transparent;
  }

  .ai-rich-text-content-{{ ai_gen_id }} {
    color: {{ block.settings.default_text_color }};
    line-height: 1.6;
    word-wrap: break-word;
  }

  .ai-rich-text-content-{{ ai_gen_id }} h1 {
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-rich-text-content-{{ ai_gen_id }} h2 {
    margin: 0 0 14px;
    line-height: 1.3;
  }

  .ai-rich-text-content-{{ ai_gen_id }} h3 {
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .ai-rich-text-content-{{ ai_gen_id }} h4 {
    margin: 0 0 10px;
    line-height: 1.4;
  }

  .ai-rich-text-content-{{ ai_gen_id }} h5 {
    margin: 0 0 8px;
    line-height: 1.4;
  }

  .ai-rich-text-content-{{ ai_gen_id }} h6 {
    margin: 0 0 8px;
    line-height: 1.4;
  }

  .ai-rich-text-content-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-rich-text-content-{{ ai_gen_id }} ul,
  .ai-rich-text-content-{{ ai_gen_id }} ol {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} strong {
    font-weight: 700;
  }

  .ai-rich-text-content-{{ ai_gen_id }} em {
    font-style: italic;
  }

  .ai-rich-text-content-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: underline;
  }

  .ai-rich-text-image-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 20px;
  }

  .ai-rich-text-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    border-radius: 8px;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-rich-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-align: center;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    margin-top: 10px;
  }

  .ai-rich-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-rich-text-bottom-button-wrapper-{{ ai_gen_id }} {
    width: 100%;
    text-align: {{ block.settings.bottom_button_alignment }};
    margin-top: {{ block.settings.bottom_button_margin_top }}px;
  }

  .ai-rich-text-bottom-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.bottom_button_padding_vertical }}px {{ block.settings.bottom_button_padding_horizontal }}px;
    background-color: {{ block.settings.bottom_button_bg_color }};
    color: {{ block.settings.bottom_button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.bottom_button_border_radius }}px;
    font-size: {{ block.settings.bottom_button_font_size }}px;
    font-weight: {{ block.settings.bottom_button_font_weight }};
    text-align: center;
    transition: all 0.3s ease;
    border: {{ block.settings.bottom_button_border_width }}px solid {{ block.settings.bottom_button_border_color }};
    cursor: pointer;
  }

  .ai-rich-text-bottom-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.bottom_button_hover_bg_color }};
    color: {{ block.settings.bottom_button_hover_text_color }};
    border-color: {{ block.settings.bottom_button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-item-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-rich-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-rich-text-container-{{ ai_gen_id }}">
    {% if block.settings.show_image %}
      <div class="ai-rich-text-item-{{ ai_gen_id }}" style="order: {{ block.settings.image_position }};">
        <div class="ai-rich-text-image-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 2000 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% else %}
            <div class="ai-rich-text-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% for i in (1..10) %}
      {% liquid
        assign enabled_key = 'text_box_' | append: i | append: '_enabled'
        assign content_key = 'text_box_' | append: i | append: '_content'
        assign heading_level_key = 'text_box_' | append: i | append: '_heading_level'
        assign font_size_key = 'text_box_' | append: i | append: '_font_size'
        assign text_color_key = 'text_box_' | append: i | append: '_text_color'
        assign alignment_key = 'text_box_' | append: i | append: '_alignment'
        assign position_key = 'text_box_' | append: i | append: '_position'
        assign show_button_key = 'text_box_' | append: i | append: '_show_button'
        assign button_text_key = 'text_box_' | append: i | append: '_button_text'
        assign button_link_key = 'text_box_' | append: i | append: '_button_link'
        assign show_image_key = 'text_box_' | append: i | append: '_show_image'
        assign image_key = 'text_box_' | append: i | append: '_image'

        assign enabled = block.settings[enabled_key]
        assign content = block.settings[content_key]
        assign heading_level = block.settings[heading_level_key]
        assign font_size = block.settings[font_size_key]
        assign text_color = block.settings[text_color_key]
        assign alignment = block.settings[alignment_key]
        assign position = block.settings[position_key]
        assign show_button = block.settings[show_button_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
        assign show_image = block.settings[show_image_key]
        assign image = block.settings[image_key]
      %}

      {% if enabled %}
        <div class="ai-rich-text-item-{{ ai_gen_id }}" style="order: {{ position }};">
          {% if show_image %}
            <div class="ai-rich-text-image-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 2000 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="ai-rich-text-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% if heading_level == 'h1' %}
            <h1
              class="ai-rich-text-content-{{ ai_gen_id }}"
              style="font-size: {{ font_size }}px; color: {{ text_color }}; text-align: {{ alignment }};"
            >
              {{ content }}
            </h1>
          {% elsif heading_level == 'h2' %}
            <h2
              class="ai-rich-text-content-{{ ai_gen_id }}"
              style="font-size: {{ font_size }}px; color: {{ text_color }}; text-align: {{ alignment }};"
            >
              {{ content }}
            </h2>
          {% elsif heading_level == 'h3' %}
            <h3
              class="ai-rich-text-content-{{ ai_gen_id }}"
              style="font-size: {{ font_size }}px; color: {{ text_color }}; text-align: {{ alignment }};"
            >
              {{ content }}
            </h3>
          {% elsif heading_level == 'h4' %}
            <h4
              class="ai-rich-text-content-{{ ai_gen_id }}"
              style="font-size: {{ font_size }}px; color: {{ text_color }}; text-align: {{ alignment }};"
            >
              {{ content }}
            </h4>
          {% elsif heading_level == 'h5' %}
            <h5
              class="ai-rich-text-content-{{ ai_gen_id }}"
              style="font-size: {{ font_size }}px; color: {{ text_color }}; text-align: {{ alignment }};"
            >
              {{ content }}
            </h5>
          {% elsif heading_level == 'h6' %}
            <h6
              class="ai-rich-text-content-{{ ai_gen_id }}"
              style="font-size: {{ font_size }}px; color: {{ text_color }}; text-align: {{ alignment }};"
            >
              {{ content }}
            </h6>
          {% else %}
            <div
              class="ai-rich-text-content-{{ ai_gen_id }}"
              style="font-size: {{ font_size }}px; color: {{ text_color }}; text-align: {{ alignment }};"
            >
              {{ content }}
            </div>
          {% endif %}

          {% if show_button and button_text != blank %}
            <a
              href="{{ button_link }}"
              class="ai-rich-text-button-{{ ai_gen_id }}"
            >
              {{ button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}

    {% if block.settings.show_bottom_button %}
      <div class="ai-rich-text-bottom-button-wrapper-{{ ai_gen_id }}">
        <a
          href="{{ block.settings.bottom_button_link }}"
          class="ai-rich-text-bottom-button-{{ ai_gen_id }}"
        >
          {{ block.settings.bottom_button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Rich text section",
  "settings": [
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "range",
      "id": "max_width",
