{% doc %}
  @prompt
    Please add a new Rich Text Section with a transparent text box that has a dropdown option to change the text to H1, H2, H3, H4, H5, H6, and paragraph. Please make everything in the text box customizable. AND, please add the option to move all text boxes up or down within the section, above or below others.
    
    The section should have the option to add up to 10 additional text boxes, all with the options listed above.
    
    The section should mirror what is in each text box, so that spacing between paragraphs, text alignment, text size, etc. shows up on the section the same way it shows up in the text box. 
    
    The background should have this gradient coding:
    > div {
      background: linear-gradient(
        to bottom right,
        #bb941b 0%,
        #e0c55a 25%,
        #be9722 50%,
        #c6a228 75%,
        #ebce66 100%
      );
    }
    
    Please add an optional image placeholder that can moved up or down in the section and be used or hidden at the user’s discretion. 
    
    Add a button at the bottom that is fully customizable, colours of the text, size of the text, and all other normal text parameters.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(
      to bottom right,
      #bb941b 0%,
      #e0c55a 25%,
      #be9722 50%,
      #c6a228 75%,
      #ebce66 100%
    );
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-rich-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-rich-text-item-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-rich-text-item-{{ ai_gen_id }} h1,
  .ai-rich-text-item-{{ ai_gen_id }} h2,
  .ai-rich-text-item-{{ ai_gen_id }} h3,
  .ai-rich-text-item-{{ ai_gen_id }} h4,
  .ai-rich-text-item-{{ ai_gen_id }} h5,
  .ai-rich-text-item-{{ ai_gen_id }} h6,
  .ai-rich-text-item-{{ ai_gen_id }} p {
    margin: 0;
    padding: 0;
  }

  .ai-rich-text-item-{{ ai_gen_id }} h1 {
    font-size: 2.5em;
    line-height: 1.2;
  }

  .ai-rich-text-item-{{ ai_gen_id }} h2 {
    font-size: 2em;
    line-height: 1.3;
  }

  .ai-rich-text-item-{{ ai_gen_id }} h3 {
    font-size: 1.75em;
    line-height: 1.3;
  }

  .ai-rich-text-item-{{ ai_gen_id }} h4 {
    font-size: 1.5em;
    line-height: 1.4;
  }

  .ai-rich-text-item-{{ ai_gen_id }} h5 {
    font-size: 1.25em;
    line-height: 1.4;
  }

  .ai-rich-text-item-{{ ai_gen_id }} h6 {
    font-size: 1em;
    line-height: 1.5;
  }

  .ai-rich-text-item-{{ ai_gen_id }} p {
    font-size: 1em;
    line-height: 1.6;
  }

  .ai-rich-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .ai-rich-text-image-{{ ai_gen_id }} {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} {
    background-color: rgba(255, 255, 255, 0.2);
    width: 100%;
    max-width: 600px;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.5;
  }

  .ai-rich-text-button-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: {{ block.settings.button_alignment }};
  }

  .ai-rich-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-transform: {{ block.settings.button_text_transform }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-rich-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-rich-text-container-{{ ai_gen_id }} {
      gap: {{ block.settings.content_spacing | times: 0.7 }}px;
    }

    .ai-rich-text-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-rich-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-rich-text-container-{{ ai_gen_id }}">
    {% liquid
      assign items = ''
      for i in (1..11)
        if i == 1
          assign position_key = 'text_1_position'
        else
          assign num = i | minus: 1
          assign position_key = 'text_' | append: num | append: '_position'
        endif
        assign position = block.settings[position_key]
        
        if i == 1
          assign item_data = 'text_1|' | append: position
        else
          assign num = i | minus: 1
          assign enabled_key = 'text_' | append: num | append: '_enabled'
          assign enabled = block.settings[enabled_key]
          if enabled
            assign item_key = 'text_' | append: num
            assign item_data = item_key | append: '|' | append: position
          else
            assign item_data = ''
          endif
        endif
        
        if item_data != ''
          if items == ''
            assign items = item_data
          else
            assign items = items | append: ',' | append: item_data
          endif
        endif
      endfor

      assign image_position = block.settings.image_position
      if block.settings.show_image
        assign image_data = 'image|' | append: image_position
        if items == ''
          assign items = image_data
        else
          assign items = items | append: ',' | append: image_data
        endif
      endif

      assign button_position = block.settings.button_position
      if block.settings.show_button
        assign button_data = 'button|' | append: button_position
        if items == ''
          assign items = button_data
        else
          assign items = items | append: ',' | append: button_data
        endif
      endif

      assign items_array = items | split: ','
      assign sorted_items = ''
      
      for pos in (1..100)
        for item in items_array
          assign item_parts = item | split: '|'
          assign item_position = item_parts[1] | plus: 0
          if item_position == pos
            if sorted_items == ''
              assign sorted_items = item_parts[0]
            else
              assign sorted_items = sorted_items | append: ',' | append: item_parts[0]
            endif
          endif
        endfor
      endfor

      assign final_items = sorted_items | split: ','
    %}

    {% for item in final_items %}
      {% if item == 'text_1' %}
        {% if block.settings.text_1_content != blank %}
          <div class="ai-rich-text-item-{{ ai_gen_id }}">
            {% case block.settings.text_1_type %}
              {% when 'h1' %}
                <h1>{{ block.settings.text_1_content }}</h1>
              {% when 'h2' %}
                <h2>{{ block.settings.text_1_content }}</h2>
              {% when 'h3' %}
                <h3>{{ block.settings.text_1_content }}</h3>
              {% when 'h4' %}
                <h4>{{ block.settings.text_1_content }}</h4>
              {% when 'h5' %}
                <h5>{{ block.settings.text_1_content }}</h5>
              {% when 'h6' %}
                <h6>{{ block.settings.text_1_content }}</h6>
              {% else %}
                {{ block.settings.text_1_content }}
            {% endcase %}
          </div>
        {% endif %}
      {% elsif item contains 'text_' %}
        {% assign text_num = item | remove: 'text_' | plus: 0 %}
        {% assign content_key = 'text_' | append: text_num | append: '_content' %}
        {% assign type_key = 'text_' | append: text_num | append: '_type' %}
        {% assign content = block.settings[content_key] %}
        {% assign type = block.settings[type_key] %}
        
        {% if content != blank %}
          <div class="ai-rich-text-item-{{ ai_gen_id }}">
            {% case type %}
              {% when 'h1' %}
                <h1>{{ content }}</h1>
              {% when 'h2' %}
                <h2>{{ content }}</h2>
              {% when 'h3' %}
                <h3>{{ content }}</h3>
              {% when 'h4' %}
                <h4>{{ content }}</h4>
              {% when 'h5' %}
                <h5>{{ content }}</h5>
              {% when 'h6' %}
                <h6>{{ content }}</h6>
              {% else %}
                {{ content }}
            {% endcase %}
          </div>
        {% endif %}
      {% elsif item == 'image' %}
        <div class="ai-rich-text-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="ai-rich-text-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-rich-text-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% elsif item == 'button' %}
        <div class="ai-rich-text-button-wrapper-{{ ai_gen_id }}">
          <a
            href="{{ block.settings.button_link }}"
            class="ai-rich-text-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

