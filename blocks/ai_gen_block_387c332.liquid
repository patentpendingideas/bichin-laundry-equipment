{% doc %}
  @prompt
    Create an FAQ section with the option to add as many questions and answers as wanted. Put it on the blue background with the option to change the background colour, and add the option to choose the font and colour of font, as well as the option to link out each FAQ question and answer to another page or section of the website.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: 40px 20px;
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    color: {{ block.settings.heading_color }};
    text-align: center;
    margin-bottom: 40px;
    font-size: 32px;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.divider_color }};
    margin-bottom: 0;
  }

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    background: none;
    border: none;
    padding: 20px 40px 20px 0;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: {{ block.settings.question_font.family }}, {{ block.settings.question_font.fallback_families }};
    font-weight: {{ block.settings.question_font.weight }};
    font-style: {{ block.settings.question_font.style }};
    color: {{ block.settings.question_color }};
    font-size: 18px;
    position: relative;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: translateY(-50%) rotate(180deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    padding: 0 0 20px 0;
    font-family: {{ block.settings.answer_font.family }}, {{ block.settings.answer_font.fallback_families }};
    font-weight: {{ block.settings.answer_font.weight }};
    font-style: {{ block.settings.answer_font.style }};
    color: {{ block.settings.answer_color }};
    font-size: 16px;
    line-height: 1.6;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 1000px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 30px;
    }

    .ai-faq-question-{{ ai_gen_id }} {
      font-size: 16px;
      padding: 16px 40px 16px 0;
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: 14px;
      padding: 0 0 16px 0;
    }
  }
{% endstyle %}

