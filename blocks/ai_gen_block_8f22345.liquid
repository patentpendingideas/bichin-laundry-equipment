{% schema %}
{
  "name": "Rich text section",
  "settings": [
    {
      "type": "header",
      "content": "Section background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#052b3e"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Text box 1"
    },
    {
      "type": "checkbox",
      "id": "text_box_1_enabled",
      "label": "Enable text box 1",
      "default": true
    },
    {
      "type": "select",
      "id": "text_box_1_type",
      "label": "Text type",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
