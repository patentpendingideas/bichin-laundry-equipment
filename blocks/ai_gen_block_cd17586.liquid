{% doc %}
  @prompt
    Please add a new Rich Text Section with transparent text boxes that have a dropdown option to change the text to H1, H2, H3, H4, H5, H6, and paragraph, another option to change the text size, another option to change the text colour, and a rich formatting tool kit that is usually standard with rich text.  
    
    Please include an option to move each text box’s position up or down within the section, above or below others.
    
    The section should have the option to add up to 10 additional text boxes, all with the options listed above.
    
    The Rich Text section should mirror what is in each text box, so that spacing between paragraphs, text alignment, text size, etc. shows up on the section the same way it shows up in the text box. 
    
    The background should have this gradient coding:
    > div {
      background: linear-gradient(
        to bottom right,
        #bb941b 0%,
        #e0c55a 25%,
        #be9722 50%,
        #c6a228 75%,
        #ebce66 100%
      );
    }
    
    Please add an optional image placeholder that can moved up or down in the section and be used or hidden at the user’s discretion. 
    
    Add a button at the bottom that is fully customizable, colours of the text, size of the text, and all other normal text parameters., remove the white background in the text boxes and make them transparent, Center all the text boxes, add the option to align text left, centre or right in each text box, add the option to add an image in each text box, for each image box, add the option to remove the image and just leave a placeholder there for a future image insert.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(
      to bottom right,
      #bb941b 0%,
      #e0c55a 25%,
      #be9722 50%,
      #c6a228 75%,
      #ebce66 100%
    );
    padding: {{ block.settings.section_padding }}px 20px;
    position: relative;
  }

  .ai-rich-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing_between_boxes }}px;
    align-items: center;
  }

  .ai-rich-text-box-{{ ai_gen_id }} {
    width: 100%;
    background: transparent;
    text-align: center;
  }

  .ai-rich-text-box-{{ ai_gen_id }}.align-left {
    text-align: left;
  }

  .ai-rich-text-box-{{ ai_gen_id }}.align-center {
    text-align: center;
  }

  .ai-rich-text-box-{{ ai_gen_id }}.align-right {
    text-align: right;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h1,
  .ai-rich-text-box-{{ ai_gen_id }} h2,
  .ai-rich-text-box-{{ ai_gen_id }} h3,
  .ai-rich-text-box-{{ ai_gen_id }} h4,
  .ai-rich-text-box-{{ ai_gen_id }} h5,
  .ai-rich-text-box-{{ ai_gen_id }} h6,
  .ai-rich-text-box-{{ ai_gen_id }} p {
    margin: 0;
    padding: 0;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h1 {
    font-size: 2.5em;
    line-height: 1.2;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h2 {
    font-size: 2em;
    line-height: 1.3;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h3 {
    font-size: 1.75em;
    line-height: 1.3;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h4 {
    font-size: 1.5em;
    line-height: 1.4;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h5 {
    font-size: 1.25em;
    line-height: 1.4;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h6 {
    font-size: 1em;
    line-height: 1.5;
  }

  .ai-rich-text-box-{{ ai_gen_id }} p {
    font-size: 1em;
    line-height: 1.6;
  }

  .ai-rich-text-box-{{ ai_gen_id }} ul,
  .ai-rich-text-box-{{ ai_gen_id }} ol {
    margin: 0;
    padding-left: 20px;
  }

  .ai-rich-text-box-{{ ai_gen_id }} strong {
    font-weight: bold;
  }

  .ai-rich-text-box-{{ ai_gen_id }} em {
    font-style: italic;
  }

  .ai-rich-text-box-{{ ai_gen_id }} a {
    text-decoration: underline;
  }

  .ai-rich-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .ai-rich-text-image-{{ ai_gen_id }} {
    max-width: {{ block.settings.image_max_width }}px;
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} {
    max-width: {{ block.settings.image_max_width }}px;
    width: 100%;
    background-color: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    min-height: 300px;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.5;
  }

  .ai-rich-text-button-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: {{ block.settings.button_margin_top }}px;
  }

  .ai-rich-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }

  .ai-rich-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-rich-text-box-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    margin: 10px 0;
  }

  .ai-rich-text-box-image-{{ ai_gen_id }} {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .ai-rich-text-box-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: 400px;
    background-color: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    min-height: 200px;
  }

  .ai-rich-text-box-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 150px;
    max-height: 150px;
    opacity: 0.5;
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 15px;
    }

    .ai-rich-text-box-{{ ai_gen_id }} h1 {
      font-size: 2em;
    }

    .ai-rich-text-box-{{ ai_gen_id }} h2 {
      font-size: 1.75em;
    }

    .ai-rich-text-box-{{ ai_gen_id }} h3 {
      font-size: 1.5em;
    }
  }
{% endstyle %}

<rich-text-section-{{ ai_gen_id }}
  class="ai-rich-text-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-rich-text-container-{{ ai_gen_id }}">
    {% liquid
      assign text_boxes = ''
      for i in (1..10)
        assign enabled_key = 'text_box_' | append: i | append: '_enabled'
        assign position_key = 'text_box_' | append: i | append: '_position'
        assign content_key = 'text_box_' | append: i | append: '_content'
        assign text_color_key = 'text_box_' | append: i | append: '_text_color'
        assign alignment_key = 'text_box_' | append: i | append: '_alignment'
        assign image_key = 'text_box_' | append: i | append: '_image'
        assign show_image_key = 'text_box_' | append: i | append: '_show_image'

        assign enabled = block.settings[enabled_key]
        assign position = block.settings[position_key]
        assign content = block.settings[content_key]
        assign text_color = block.settings[text_color_key]
        assign alignment = block.settings[alignment_key]
        assign image = block.settings[image_key]
        assign show_image = block.settings[show_image_key]

        if enabled
          assign box_data = position | append: '|' | append: i | append: '|' | append: content | append: '|' | append: text_color | append: '|' | append: alignment | append: '|' | append: image | append: '|' | append: show_image
          if text_boxes == ''
            assign text_boxes = box_data
          else
            assign text_boxes = text_boxes | append: '||' | append: box_data
          endif
        endif
      endfor

      assign sorted_boxes = text_boxes | split: '||' | sort
    %}

    {% for box_data in sorted_boxes %}
      {% assign box_parts = box_data | split: '|' %}
      {% assign box_index = box_parts[1] %}

      {% liquid
        assign content_key = 'text_box_' | append: box_index | append: '_content'
        assign text_color_key = 'text_box_' | append: box_index | append: '_text_color'
        assign alignment_key = 'text_box_' | append: box_index | append: '_alignment'
        assign image_key = 'text_box_' | append: box_index | append: '_image'
        assign show_image_key = 'text_box_' | append: box_index | append: '_show_image'

        assign actual_content = block.settings[content_key]
        assign actual_color = block.settings[text_color_key]
        assign actual_alignment = block.settings[alignment_key]
        assign actual_image = block.settings[image_key]
        assign actual_show_image = block.settings[show_image_key]
      %}

      <div
        class="ai-rich-text-box-{{ ai_gen_id }} align-{{ actual_alignment }}"
        style="color: {{ actual_color }};"
      >
        {% if actual_show_image %}
          <div class="ai-rich-text-box-image-wrapper-{{ ai_gen_id }}">
            {% if actual_image %}
              <img
                src="{{ actual_image | image_url: width: 800 }}"
                alt="{{ actual_image.alt | escape }}"
                class="ai-rich-text-box-image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ actual_image.width }}"
                height="{{ actual_image.height }}"
              >
            {% else %}
              <div class="ai-rich-text-box-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        {% endif %}
        {{ actual_content }}
      </div>
    {% endfor %}

    {% if block.settings.show_image %}
      {% liquid
        assign image_position = block.settings.image_position
        assign image_inserted = false
        assign current_position = 0
      %}

      {% if image_position == 0 or sorted_boxes.size == 0 %}
        <div class="ai-rich-text-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.section_image %}
            <img
              src="{{ block.settings.section_image | image_url: width: 1200 }}"
              alt="{{ block.settings.section_image.alt | escape }}"
              class="ai-rich-text-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.section_image.width }}"
              height="{{ block.settings.section_image.height }}"
            >
          {% else %}
            <div class="ai-rich-text-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    {% if block.settings.show_button %}
      <div class="ai-rich-text-button-wrapper-{{ ai_gen_id }}">
        <a
          href="{{ block.settings.button_link }}"
          class="ai-rich-text-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</rich-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class RichTextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.insertImageAtPosition();
      }

      insertImageAtPosition() {
        const imagePosition = {{ block.settings.image_position }};
        const showImage = {{ block.settings.show_image }};
        
        if (!showImage || imagePosition === 0) return;

        const container = this.querySelector('.ai-rich-text-container-{{ ai_gen_id }}');
        const textBoxes = container.querySelectorAll('.ai-rich-text-box-{{ ai_gen_id }}');
        const imageWrapper = container.querySelector('.ai-rich-text-image-wrapper-{{ ai_gen_id }}');
        
        if (!imageWrapper && textBoxes.length > 0 && imagePosition <= textBoxes.length) {
          const newImageWrapper = document.createElement('div');
          newImageWrapper.className = 'ai-rich-text-image-wrapper-{{ ai_gen_id }}';
          
          {% if block.settings.section_image %}
            newImageWrapper.innerHTML = `
              <img
                src="{{ block.settings.section_image | image_url: width: 1200 }}"
                alt="{{ block.settings.section_image.alt | escape }}"
                class="ai-rich-text-image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ block.settings.section_image.width }}"
                height="{{ block.settings.section_image.height }}"
              >
            `;
          {% else %}
            newImageWrapper.innerHTML = `
              <div class="ai-rich-text-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            `;
          {% endif %}
          
          if (imagePosition <= textBoxes.length) {
            textBoxes[imagePosition - 1].insertAdjacentElement('afterend', newImageWrapper);
          }
        }
      }
    }

    customElements.define('rich-text-section-{{ ai_gen_id }}', RichTextSection{{ ai_gen_id }});
  })();
</script>

