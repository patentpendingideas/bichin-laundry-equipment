{% doc %}
  @prompt
    Please add a new Rich Text Section with transparent text boxes that have a dropdown option to change the text to H1, H2, H3, H4, H5, H6, and paragraph, another option to change the text size, another option to change the text colour, and a rich formatting tool kit that is usually standard with rich text.  
    
    Please include an option to move each text box’s position up or down within the section, above or below others.
    
    The section should have the option to add up to 10 additional text boxes, all with the options listed above.
    
    The Rich Text section should mirror what is in each text box, so that spacing between paragraphs, text alignment, text size, etc. shows up on the section the same way it shows up in the text box. 
    
    The background should have this gradient coding:
    > div {
      background: linear-gradient(
        to bottom right,
        #bb941b 0%,
        #e0c55a 25%,
        #be9722 50%,
        #c6a228 75%,
        #ebce66 100%
      );
    }
    
    Please add an optional image placeholder that can moved up or down in the section and be used or hidden at the user’s discretion. 
    
    Add a button at the bottom that is fully customizable, colours of the text, size of the text, and all other normal text parameters., remove the white background in the text boxes and make them transparent, Center all the text boxes, add the option to align text left, centre or right in each text box, add the option to add an image in each text box
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(
      to bottom right,
      #bb941b 0%,
      #e0c55a 25%,
      #be9722 50%,
      #c6a228 75%,
      #ebce66 100%
    );
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-rich-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing_between_items }}px;
  }

  .ai-rich-text-box-{{ ai_gen_id }} {
    background-color: transparent;
    padding: {{ block.settings.text_box_padding }}px;
    border-radius: {{ block.settings.text_box_border_radius }}px;
    order: var(--ai-order-{{ ai_gen_id }});
    text-align: var(--ai-text-align-{{ ai_gen_id }});
  }

  .ai-rich-text-box-content-{{ ai_gen_id }} {
    margin-bottom: 15px;
  }

  .ai-rich-text-box-content-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h1,
  .ai-rich-text-box-{{ ai_gen_id }} h2,
  .ai-rich-text-box-{{ ai_gen_id }} h3,
  .ai-rich-text-box-{{ ai_gen_id }} h4,
  .ai-rich-text-box-{{ ai_gen_id }} h5,
  .ai-rich-text-box-{{ ai_gen_id }} h6,
  .ai-rich-text-box-{{ ai_gen_id }} p {
    margin: 0;
    padding: 0;
  }

  .ai-rich-text-box-{{ ai_gen_id }} h1 {
    font-size: var(--ai-font-size-{{ ai_gen_id }});
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-{{ ai_gen_id }} h2 {
    font-size: var(--ai-font-size-{{ ai_gen_id }});
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-{{ ai_gen_id }} h3 {
    font-size: var(--ai-font-size-{{ ai_gen_id }});
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-{{ ai_gen_id }} h4 {
    font-size: var(--ai-font-size-{{ ai_gen_id }});
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-{{ ai_gen_id }} h5 {
    font-size: var(--ai-font-size-{{ ai_gen_id }});
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-{{ ai_gen_id }} h6 {
    font-size: var(--ai-font-size-{{ ai_gen_id }});
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-{{ ai_gen_id }} p {
    font-size: var(--ai-font-size-{{ ai_gen_id }});
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-{{ ai_gen_id }} * {
    color: var(--ai-text-color-{{ ai_gen_id }});
  }

  .ai-rich-text-box-image-{{ ai_gen_id }} {
    width: 100%;
    margin-top: 15px;
  }

  .ai-rich-text-box-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.text_box_image_border_radius }}px;
  }

  .ai-rich-text-box-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: {{ block.settings.text_box_image_border_radius }}px;
    overflow: hidden;
  }

  .ai-rich-text-box-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-rich-text-image-{{ ai_gen_id }} {
    order: var(--ai-image-order-{{ ai_gen_id }});
    width: 100%;
  }

  .ai-rich-text-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-rich-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-rich-text-button-wrapper-{{ ai_gen_id }} {
    order: 999;
    display: flex;
    justify-content: {{ block.settings.button_alignment }};
  }

  .ai-rich-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }

  .ai-rich-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 15px;
    }
  }
{% endstyle %}

