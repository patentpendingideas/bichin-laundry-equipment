      "label": "Padding horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Text box 1"
    },
    {
      "type": "checkbox",
      "id": "show_text_box_1",
      "label": "Show text box 1",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "text_box_1_heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "select",
      "id": "text_box_1_heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
