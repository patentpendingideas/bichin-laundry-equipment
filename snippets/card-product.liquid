              >
                {{- 'products.product.sold_out' | t -}}
              </span>
            {%- elsif card_product.compare_at_price > card_product.price and card_product.available -%}
              <span
                id="Badge-{{ section_id }}-{{ card_product.id }}"
                class="badge badge--bottom-left"
              >
                - {{ card_product.compare_at_price | minus: card_product.price | times: 100 | divided_by: card_product.compare_at_price }}%
              </span>
            {%- endif -%}
            {% for tag in card_product.tags %}
                {% if tag contains "label_" %}
                  <span class="badge custom_pro_badge">
                  {{ tag | remove: "label_" | capitalize | split: "_" | last }}
                  </span>
                {% endif %}
              {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
